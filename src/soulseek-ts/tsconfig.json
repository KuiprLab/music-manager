{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "../../dist/soulseek-ts",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "strict": false,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": false,
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "moduleDetection": "force",
    "sourceMap": true,
    "declaration": true
  },
  "include": ["./**/*"]
}
